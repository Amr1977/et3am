#!/bin/sh
# Post-push hook: Deploy after successful push to master
# Only runs on master branch

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "master" ]; then
    echo "On master branch - running post-push deployment..."
    cd "$(dirname "$0")/.."
    ./deploy-all.sh
fi

echo ""
echo "==========================================="
echo "⚠️  REMINDER: Update Trello & KB after this push?"
echo "==========================================="
echo ""
echo "Trello: Move completed cards to DONE"
echo "  cd backend && npm run trello done 'TASK-ID'"
echo ""
echo "KB: Document what you learned?"
echo "Ask yourself:"
echo "  1. What technique/pattern did I use?"
echo "  2. What pitfalls did I encounter?"
echo "  3. Can this be generalized/reused?"
echo ""
echo "If yes → Update docs/kb/ and push"
echo ""