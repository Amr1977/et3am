# Database (using DATABASE_URL for Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/et3am

# Security (REQUIRED for production)
JWT_SECRET=min-64-char-random-string-here-change-in-production
CORS_ORIGIN=https://www.et3am.com,https://et3am.com,https://et3am26.web.app,https://api.et3am.com,https://et3am-api.mywire.org

# Firebase (get from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@et3am26.iam.gserviceaccount.com
FIREBASE_PROJECT_ID=et3am26

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://et3am26.web.app

# Optional: Google OAuth (leave empty to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://api.et3am.com/api/auth/google/callback
