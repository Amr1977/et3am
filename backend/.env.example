# Database (use Neon, Supabase, or local PostgreSQL)
# For local: postgresql://postgres:password@localhost:5432/et3am
# For Neon: postgresql://user:password@host.neon.tech/et3am?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/et3am

# Security (REQUIRED - generate a 64+ character random string)
JWT_SECRET=replace-with-a-strong-random-secret-key-min-64-chars
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Firebase (REQUIRED - get from Firebase Console > Project Settings > Service Accounts)
# 1. Go to https://console.firebase.google.com
# 2. Create a project (or use existing)
# 3. Project Settings > Service Accounts > Generate new private key
# 4. Copy the values below
FIREBASE_PRIVATE_KEY=your-firebase-private-key-here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@project-id.iam.gserviceaccount.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional: Google OAuth (leave empty to disable)
# 1. Go to https://console.cloud.google.com
# 2. Enable Google+ API
# 3. Create OAuth credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Telegram Admin Notifications (optional)
# Get your chat ID: https://t.me/userinfobot
TELEGRAM_ADMIN_CHAT_ID=

# Service Monitoring
FE_URL=https://foodshare777.web.app
BE_URL=https://api.et3am.com
HEALTH_CHECK_INTERVAL=60000
