{
  "name": "et3am-backend",
  "version": "1.0.0",
  "description": "Food Donation Platform Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:staging": "ts-node -r dotenv/config src/server.ts dotenv_config_path=.env.staging",
    "dev:test": "ts-node -r dotenv/config src/server.ts dotenv_config_path=.env.testing",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:staging": "node -r dotenv/config dist/server.js dotenv_config_path=.env.staging",
    "start:test": "node -r dotenv/config dist/server.js dotenv_config_path=.env.testing",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:run:coverage": "vitest run --coverage",
    "test:report": "vitest run --coverage",
    "migrate": "ts-node src/migrate.ts",
    "migrate:run": "ts-node src/migrate.ts",
    "migrate:staging": "ts-node -r dotenv/config src/migrate.ts dotenv_config_path=.env.staging",
    "migrate:test": "ts-node -r dotenv/config src/migrate.ts dotenv_config_path=.env.testing",
    "trello": "node trello-cli.js"
  },
  "dependencies": {
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "socket.io": "^4.7.4",
    "telegraf": "^4.16.3",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
